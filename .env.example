# Environment variables for docker compose (copy to .env for local overrides)
#
# Docker Compose project name is set in docker-compose.yml as "cohestra-infra"
# (containers: cohestra-infra-api-1, volumes: cohestra-infra_postgres_data, etc.).
# Cohestra is independent from the single-operator lead-generation-crm product.
# If both run locally, use non-default host ports below to avoid conflicts.

# Public URL — must match what you type in the browser (nginx routes / and /api/)
PUBLIC_BASE_URL=http://localhost
# NGINX_HTTP_PORT=8088   # use if port 80 is taken by another product
# POSTGRES_HOST_PORT=5433  # use if 5432 is taken by another product
# REDIS_HOST_PORT=6380     # use if 6379 is taken by another product
# API_HOST_PORT=8080   # direct API link in Docker Desktop (optional; nginx also proxies /api/)
# WEB_HOST_PORT=3000   # direct web link in Docker Desktop (optional; prefer http://localhost via nginx)

# PostgreSQL (postgres service)
POSTGRES_DB=cohestra
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm

# API (api service) — override appsettings when running via Compose
# ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=cohestra;Username=crm;Password=crm
# ConnectionStrings__Redis=redis:6379
# ASPNETCORE_URLS=http://+:8080
# Jwt__SigningKey=dev-compose-jwt-signing-key-min-32-chars!!
# OperatorSeed__Email=operator@cohestra.local
# OperatorSeed__Password=ChangeMe123!
# Optional: set OperatorSeed__Enabled=true to auto-create an operator on first startup (skips /register onboarding).
# OperatorSeed__Enabled=false
# DemoDataSeed__Enabled=false

# SendGrid (api service) — set SendGrid__ApiKey in .env (never commit the key)
# After creating or rotating a key, replace the FULL secret below and recreate the API container:
#   docker compose up -d --force-recreate api
# Editing permissions on an existing SendGrid key does NOT change the secret — create a new key if needed.
# SendGrid__ApiKey=your-sendgrid-api-key
# SendGrid__FromEmail=noreply@cohestra.app
# SendGrid__FromName=Cohestra
# SendGrid__RegistrationFromEmail=noreply@cohestra.app
# SendGrid__RegistrationFromName=Cohestra
# SendGrid__UseSandbox=false
# EmailBranding__WebsiteUrl=https://cohestra.app
# EmailBranding__FooterLegalName=Cohestra
# EmailBranding__LogoUrl=https://your-domain.com/brand/cohestra-logo.svg

# Landing page defaults (web build args + API SiteLanding seed)
# LANDING_SITE_NAME=Cohestra
# LANDING_TAGLINE=Community events. Meaningful connections.
# LANDING_EYEBROW=Community events platform

# Web (web service) — browser uses PUBLIC_BASE_URL via nginx; SSR uses internal API_URL
# NEXT_PUBLIC_API_URL is set from PUBLIC_BASE_URL at build time in docker-compose.yml
# API_URL=http://api:8080
