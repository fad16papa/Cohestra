FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_URL=http://localhost:8080
ARG NEXT_PUBLIC_LANDING_SITE_NAME=
ARG NEXT_PUBLIC_LANDING_TAGLINE=
ARG NEXT_PUBLIC_LANDING_DESCRIPTION=
ARG NEXT_PUBLIC_LANDING_EYEBROW=
ARG NEXT_PUBLIC_LANDING_OPERATOR_CTA=
ARG NEXT_PUBLIC_RECAPTCHA_ENABLED=false
ARG NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
ARG NEXT_PUBLIC_RECAPTCHA_TEST_TOKEN=test-captcha-pass
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_LANDING_SITE_NAME=$NEXT_PUBLIC_LANDING_SITE_NAME
ENV NEXT_PUBLIC_LANDING_TAGLINE=$NEXT_PUBLIC_LANDING_TAGLINE
ENV NEXT_PUBLIC_LANDING_DESCRIPTION=$NEXT_PUBLIC_LANDING_DESCRIPTION
ENV NEXT_PUBLIC_LANDING_EYEBROW=$NEXT_PUBLIC_LANDING_EYEBROW
ENV NEXT_PUBLIC_LANDING_OPERATOR_CTA=$NEXT_PUBLIC_LANDING_OPERATOR_CTA
ENV NEXT_PUBLIC_RECAPTCHA_ENABLED=$NEXT_PUBLIC_RECAPTCHA_ENABLED
ENV NEXT_PUBLIC_RECAPTCHA_SITE_KEY=$NEXT_PUBLIC_RECAPTCHA_SITE_KEY
ENV NEXT_PUBLIC_RECAPTCHA_TEST_TOKEN=$NEXT_PUBLIC_RECAPTCHA_TEST_TOKEN
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:22-alpine AS final
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
EXPOSE 3000
COPY --from=build /app/public ./public
COPY --from=build /app/.next/standalone ./
COPY --from=build /app/.next/static ./.next/static
CMD ["node", "server.js"]
