# Cloud mobile testing — copy to .env on your DigitalOcean droplet.
#   cp .env.cloud-mobile.example .env
#   bash deploy/setup-cloud-mobile.sh
#
# Opens marketing + signup on HTTPS nip.io so phones can test without a custom domain.
# Does NOT change local docker-compose.yml behavior.

# --- After setup-cloud-mobile.sh runs, this becomes https://YOUR-IP-HYPHENS.nip.io ---
PUBLIC_BASE_URL=https://129-212-235-2.nip.io

# Let's Encrypt contact (required for HTTPS script)
LETSENCRYPT_EMAIL=you@example.com

# Optional overrides (auto-detected by setup-cloud-mobile.sh)
# DROPLET_IP=129.212.235.2
# HTTPS_DOMAIN=129-212-235-2.nip.io
# NGINX_CONFIG_PATH=./deploy/nginx/active-ssl.conf

# --- PostgreSQL ---
POSTGRES_DB=cohestra
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me-strong-postgres-password

# --- JWT (min 32 characters) ---
JWT_SIGNING_KEY=change-me-jwt-signing-key-at-least-32-characters-long
JWT_ISSUER=cohestra
JWT_AUDIENCE=cohestra-api

# --- Self-serve signup (Story 14.3) — CAPTCHA off until you add reCAPTCHA keys ---
SelfServeSignup__RegistrationClosed=false
SelfServeSignup__Recaptcha__Enabled=false
SelfServeSignup__Recaptcha__TestBypassToken=test-captcha-pass
NEXT_PUBLIC_RECAPTCHA_ENABLED=false
NEXT_PUBLIC_RECAPTCHA_TEST_TOKEN=test-captcha-pass

# When enabling reCAPTCHA in production cloud:
# SelfServeSignup__Recaptcha__Enabled=true
# SelfServeSignup__Recaptcha__SecretKey=your-secret
# NEXT_PUBLIC_RECAPTCHA_ENABLED=true
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
# Then: docker compose -f docker-compose.uat.yml up -d --build web api

# --- SendGrid (REQUIRED for UAT stack — OTP emails for signup) ---
SendGrid__ApiKey=SG.replace-with-live-mail-send-api-key
SendGrid__FromEmail=noreply@cohestra.app
SendGrid__FromName=Cohestra
SendGrid__RegistrationFromEmail=noreply@cohestra.app
SendGrid__RegistrationFromName=Cohestra
EmailBranding__WebsiteUrl=https://cohestra.app
EmailBranding__FooterLegalName=Cohestra
