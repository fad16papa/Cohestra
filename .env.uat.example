# Copy to .env on the Ubuntu droplet before: docker compose -f docker-compose.uat.yml up -d --build
# Never commit .env — it contains secrets.
#
# Docker Compose project name: cohestra-infra-uat (set in docker-compose.uat.yml)
# This stack runs as Production (real SendGrid delivery — not sandbox).

# --- Public URL (must match browser address — nginx entry point) ---
# Local Docker: http://localhost (or http://localhost:8088 if NGINX_HTTP_PORT=8088)
# UAT droplet (no domain, HTTP only): http://YOUR_DROPLET_IP
# Temporary HTTPS (nip.io): https://129-212-235-2.nip.io — see docs/deploy/temporary-https-nipio.md
# Production: https://your-domain.com
PUBLIC_BASE_URL=http://localhost

# nginx host port (default 80 / 443)
# NGINX_HTTP_PORT=8088

# --- Temporary HTTPS (nip.io + Let's Encrypt) — optional ---
# Run once on droplet: bash deploy/setup-temporary-https.sh
# LETSENCRYPT_EMAIL=you@example.com
# DROPLET_IP=129.212.235.2
# HTTPS_DOMAIN=129-212-235-2.nip.io
# NGINX_CONFIG_PATH=./deploy/nginx/active-ssl.conf

# --- Client domain (thesocialcollectivesg.com) ---
# PUBLIC_BASE_URL=https://thesocialcollectivesg.com
# bash deploy/switch-https-domain.sh thesocialcollectivesg.com you@example.com
# See docs/deploy/client-domain-thesocialcollectivesg.md

# --- Public landing page at / (baked into web image) ---
# FALLBACK-ONLY after Epic 9 Website Builder: used to seed a fresh database and when
# no published Site Page exists. Homepage copy is edited in Website builder after first publish.
# API seed uses SiteLanding__* (see docker-compose SiteLanding__* on the api service).
# LANDING_SITE_NAME=The Social Collective
# LANDING_TAGLINE=Community activities. Meaningful connections.
# LANDING_DESCRIPTION=Join our events, register in seconds, and stay connected with the communities you care about.
# LANDING_EYEBROW=Singapore · Community events
# LANDING_OPERATOR_CTA=Operator sign in

# --- PostgreSQL ---
POSTGRES_DB=cohestra
POSTGRES_USER=crm
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-postgres-password

# --- JWT (min 32 characters) ---
# Generate: openssl rand -base64 48
JWT_SIGNING_KEY=change-me-jwt-signing-key-at-least-32-characters-long
JWT_ISSUER=cohestra
JWT_AUDIENCE=cohestra-api

# --- Operator (first-time setup via /register + OTP; seed disabled by default) ---
# Optional dev override — auto-create operator on first startup:
# OperatorSeed__Enabled=true
# OperatorSeed__Email=operator@yourclient.com
# OperatorSeed__Password=change-me-strong-operator-password

# --- SendGrid (REQUIRED — live production delivery) ---
# See docs/deploy/sendgrid-production.md for DNS + sender setup.
SendGrid__ApiKey=SG.replace-with-live-mail-send-api-key
SendGrid__FromEmail=noreply@creativorare.com
SendGrid__FromName=Creativorare
SendGrid__RegistrationFromEmail=noreply@creativorare.com
SendGrid__RegistrationFromName=Creativorare
EmailBranding__WebsiteUrl=https://creativorare.com
EmailBranding__FooterLegalName=Creativorare
# UseSandbox is locked to false in docker-compose.uat.yml — do not enable sandbox on this deploy.

# --- Database tools (pgAdmin / RedisInsight) ---
# Postgres and Redis bind to 127.0.0.1 on the droplet only.
# Connect from your laptop via SSH tunnel — see docs/deploy/database-tools.md
